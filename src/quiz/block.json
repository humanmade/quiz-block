{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 2,
    "name": "hmquiz/quiz",
    "version": "1.0.0",
    "title": "Quiz",
    "category": "hmquiz",
    "icon": "list-view",
    "description": "Multi-step quiz container. Add Quiz Question blocks inside.",
    "supports": { "html": false },
    "style": "hmquiz-style",
    "editorStyle": "hmquiz-editor-style",
    "editorScript": "file:./index.js",
    "example": {
        "innerBlocks": [
            {
                "name": "hmquiz/question",
                "attributes": {
                    "question": "What is the capital of France?",
                    "alternatives": [
                        { "id": "a", "text": "London" },
                        { "id": "b", "text": "Paris" },
                        { "id": "c", "text": "Berlin" }
                    ],
                    "correctAnswer": "b"
                }
            }
        ]
    }
}
